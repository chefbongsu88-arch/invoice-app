# Copy to .env.local (local) or set the same keys in Railway → Variables.
#   copy .env.example .env.local
#
# Receipt links in Google Sheets must stay short HTTPS URLs (not huge data URLs).
# When both Forge variables below are set, exports upload receipts there first.

# Manus / Forge storage API (required together for persistent receipt URLs in Sheets).
# Manus “Application secrets” may use these names instead — both work on the server:
# BUILT_IN_FORGE_API_URL=   OR   VITE_FRONTEND_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=   OR   VITE_FRONTEND_FORGE_API_KEY=
# Use the exact API origin from Manus “Reveal” (storage proxy). Guessing https://forge.manus.ai often returns HTTP 400 record not found.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Optional: explicit public API origin for receipt links (otherwise Railway / constants fallback)
# PUBLIC_SERVER_URL=https://your-service.up.railway.app
# RECEIPT_IMAGE_PUBLIC_BASE_URL=https://your-service.up.railway.app

# Optional: persist /api/receipt-share blobs on disk (mount a Railway volume here for durability).
# RECEIPT_SHARE_DISK_DIR=/data/receipt-share
# On Railway, .data/receipt-share under the app is used automatically unless RECEIPT_SHARE_DISK_OFF=1.
# RECEIPT_SHARE_DISK_OFF=1

# Receipt OCR (server): set at least one of Anthropic, Google AI Studio Gemini, or Forge (above).
# ANTHROPIC_API_KEY=
# GOOGLE_GEMINI_API_KEY=   # or GEMINI_API_KEY=
#
# Stability / log noise (recommended on Railway when both keys are set):
# - Default: Claude first, Gemini only if Claude fails (reduces Gemini free-tier 429 spam).
# - OCR_GEMINI_FIRST=1 — restore Gemini-first (better for some picky photos; more Gemini calls).
# - OCR_SKIP_GEMINI=1 — never call Gemini for receipt/image/scanned-PDF OCR (Claude/Forge only).
# OCR_SKIP_GEMINI=1
